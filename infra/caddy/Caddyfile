# Ankara — Caddy reverse proxy
# Replace ankara.example.com with your actual domain.
# In local dev, use localhost and comment out TLS blocks.

api.ankara.example.com {
    reverse_proxy localhost:8000
}

admin.ankara.example.com {
    reverse_proxy localhost:3000
}

labeling.ankara.example.com {
    reverse_proxy localhost:8080
}

staging.ankara.example.com {
    reverse_proxy localhost:3001
}
