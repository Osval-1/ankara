# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME="Ankara"
ENVIRONMENT=local   # local | staging | production

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
POSTGRES_USER=cropdoctor
POSTGRES_PASSWORD=changeme
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cropdoctor

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6379
REDIS_RATE_LIMIT_HOST=localhost
REDIS_RATE_LIMIT_PORT=6379

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── First superuser (seeded on startup) ─────────────────────────────────────
ADMIN_NAME="Ankara Admin"
ADMIN_EMAIL=admin@ankara.example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Clerk (web + mobile auth for extension workers / admins) ────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_changeme
CLERK_SECRET_KEY=sk_test_changeme

# ─── WhatsApp (360dialog) ────────────────────────────────────────────────────
WHATSAPP_API_KEY=changeme
WHATSAPP_WEBHOOK_SECRET=changeme
WHATSAPP_PHONE_NUMBER_ID=changeme

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=changeme

# ─── Cloudflare R2 (object storage) ─────────────────────────────────────────
R2_ACCOUNT_ID=changeme
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_BUCKET_PHOTOS_RAW=ankara-photos-raw
R2_BUCKET_PHOTOS_CURATED=ankara-photos-curated
R2_BUCKET_MODELS=ankara-models

# ─── ML Inference service ────────────────────────────────────────────────────
ML_SERVICE_HOST=localhost
ML_SERVICE_PORT=8501

# ─── Next.js web app ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Expo mobile app ─────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_APP_ENV=development

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
